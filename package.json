{
  "name": "devildogcyber-webapp",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pnpm --filter api run build && node --experimental-strip-types scripts/verify-build-seo.ts && node scripts/check-js-budget.mjs",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && pnpm --filter api typecheck"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.0",
    "@astrojs/sitemap": "^3.6.0",
    "@fontsource/montserrat": "^5.2.5",
    "@fontsource/open-sans": "^5.2.5",
    "@tailwindcss/vite": "^4.1.4",
    "astro": "^5.18.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "axe-core": "^4.11.4",
    "eslint": "^9.26.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "happy-dom": "^17.4.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
