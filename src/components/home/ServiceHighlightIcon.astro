---
import type { ServiceHighlight } from "../../content/siteContent";

type Props = { icon: ServiceHighlight["icon"] };

const { icon } = Astro.props;
const iconClassName = "h-6 w-6 stroke-current";
---

{
  icon === "person" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path d="M12 12a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z" stroke-width="1.8" />
      <path d="M5 19.5a7 7 0 0 1 14 0" stroke-width="1.8" stroke-linecap="round" />
    </svg>
  )
}
{
  icon === "cloud" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path
        d="M7 18.5h9.5a4 4 0 0 0 .65-7.95A5.5 5.5 0 0 0 6.54 9.1 4.5 4.5 0 0 0 7 18.5Z"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}
{
  icon === "pulse" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path
        d="M3 12h4l2-4 4 8 2-4h6"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}
{
  icon === "shield" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path
        d="M12 4.5 5.5 7v4.75c0 4.1 2.66 7.9 6.5 9.25 3.84-1.35 6.5-5.15 6.5-9.25V7L12 4.5Z"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
    </svg>
  )
}
{
  icon === "sliders" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path d="M5 6h14M5 12h14M5 18h14" stroke-width="1.8" stroke-linecap="round" />
      <circle cx="9" cy="6" r="2" fill="currentColor" />
      <circle cx="15" cy="12" r="2" fill="currentColor" />
      <circle cx="11" cy="18" r="2" fill="currentColor" />
    </svg>
  )
}
{
  icon === "training" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path
        d="m3 9 9-4 9 4-9 4-9-4Zm3 2.75v4.5L12 19l6-2.75v-4.5"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}
{
  icon === "check" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path d="m7.5 12.5 3 3 6-7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      <path
        d="M12 4.5 5.5 7v4.75c0 4.1 2.66 7.9 6.5 9.25 3.84-1.35 6.5-5.15 6.5-9.25V7L12 4.5Z"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
    </svg>
  )
}
{
  icon === "clipboard" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path
        d="M9 5.5h6M9.75 4h4.5A1.75 1.75 0 0 1 16 5.75V7h1.25A1.75 1.75 0 0 1 19 8.75v9.5A1.75 1.75 0 0 1 17.25 20h-10.5A1.75 1.75 0 0 1 5 18.25v-9.5A1.75 1.75 0 0 1 6.75 7H8V5.75A1.75 1.75 0 0 1 9.75 4Z"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
      <path d="M12 10v4M10 12h4" stroke-width="1.8" stroke-linecap="round" />
    </svg>
  )
}
{
  icon === "certificate" && (
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class={iconClassName}>
      <path
        d="M12 6.5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Z"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
      <path
        d="m9.5 14.5-1.25 5 3.75-1.75L15.75 19l-1.25-4.5"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}
