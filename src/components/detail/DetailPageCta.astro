---
import type { PageTheme } from "../../content/detailPages";

export type Props = {
  theme: PageTheme;
  title: string;
  description: string;
  primaryAction?: { label: string; href: string };
  secondaryAction?: { label: string; href: string };
};

const { theme, title, description, primaryAction, secondaryAction } = Astro.props;

const wrapper =
  theme === "dark"
    ? "bg-[linear-gradient(180deg,var(--dd-red),var(--dd-red-deep))] border-white/10 text-white shadow-[0_24px_65px_rgba(0,0,0,0.18)]"
    : "border-[color:var(--dd-border)] bg-white text-[color:var(--dd-copy)] shadow-[0_18px_50px_rgba(15,23,42,0.1)]";

const muted = theme === "dark" ? "text-white/82" : "text-[color:var(--dd-muted)]";
---

<section class:list={["scroll-mt-28 rounded-[2rem] border p-10 sm:p-12", wrapper]}>
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="font-display text-3xl font-extrabold tracking-tight sm:text-4xl">
      {title}
    </h2>
    <p class:list={["mt-5 text-base leading-8 sm:text-lg", muted]}>{description}</p>
    {
      primaryAction ? (
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <a
            href={primaryAction.href}
            class:list={[
              "inline-flex min-h-[2.75rem] items-center justify-center rounded-xl px-6 text-sm font-semibold uppercase tracking-[0.12em]",
              theme === "dark"
                ? "bg-white text-[color:var(--dd-red)] hover:bg-dd-cream"
                : "bg-[color:var(--dd-red)] text-white hover:bg-[color:var(--dd-red-deep)]",
            ]}
          >
            {primaryAction.label}
          </a>
          {secondaryAction ? (
            <a
              href={secondaryAction.href}
              class:list={[
                "inline-flex min-h-[2.75rem] items-center justify-center rounded-xl border px-6 text-sm font-semibold uppercase tracking-[0.12em]",
                theme === "dark"
                  ? "border-white/35 text-white hover:border-white hover:bg-white/10"
                  : "border-[color:var(--dd-border)] text-[color:var(--dd-copy)] hover:border-[color:var(--dd-red)] hover:bg-dd-cream/60",
              ]}
            >
              {secondaryAction.label}
            </a>
          ) : null}
        </div>
      ) : null
    }
  </div>
</section>
