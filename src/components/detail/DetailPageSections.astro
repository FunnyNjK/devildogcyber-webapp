---
import DetailPageCta from "./DetailPageCta.astro";
import DetailSplitSection from "./DetailSplitSection.astro";

import ContentImage from "../ContentImage.astro";
import type { DetailPage, DetailPageSection } from "../../content/detailPages";

export type Props = {
  sections: DetailPage["sections"];
  cta?: DetailPage["cta"];
};

const { sections, cta } = Astro.props;

function sectionShell(theme: DetailPageSection["theme"], rounded = "rounded-[2rem]") {
  const light = `border-[color:var(--dd-border)] bg-white text-[color:var(--dd-copy)] shadow-[0_18px_45px_rgba(15,23,42,0.08)] ${rounded}`;
  const dark =
    "border-white/12 bg-[linear-gradient(155deg,var(--dd-red-deep),var(--dd-red)_48%,rgba(176,17,22,0.94))] text-white shadow-[0_24px_68px_rgba(0,0,0,0.22)] " +
    rounded;
  return theme === "dark" ? dark : light;
}

function muted(theme: DetailPageSection["theme"]) {
  return theme === "dark" ? "text-white/76" : "text-[color:var(--dd-muted)]";
}

function eyebrow(theme: DetailPageSection["theme"]) {
  return theme === "dark"
    ? "text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-white/72"
    : "text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-[color:var(--dd-red-bright)]";
}

const cardGrid = (cols: 2 | 3 | 4) =>
  cols === 2 ? "grid gap-8 md:grid-cols-2" : cols === 4 ? "grid gap-8 md:grid-cols-2 xl:grid-cols-4" : "grid gap-8 md:grid-cols-2 xl:grid-cols-3";
---

<div class="mx-auto mt-14 flex w-full max-w-7xl flex-col gap-14 px-6 pb-28 sm:mt-18 sm:gap-16 lg:gap-18">
  {
    sections.map((section, index) =>
      section.kind === "split" ? (
        <DetailSplitSection section={section} index={index} />
      ) : section.kind === "cards" ? (
        <section data-section-index={index} class:list={["scroll-mt-28 border px-8 py-12 sm:px-10 sm:py-14", sectionShell(section.theme)]}>
          {section.eyebrow ? <p class={eyebrow(section.theme)}>{section.eyebrow}</p> : null}
          <h2 class="mt-3 max-w-4xl font-display text-3xl font-extrabold tracking-tight sm:text-4xl">{section.title}</h2>
          {section.description ? <p class:list={["mt-4 max-w-3xl leading-8", muted(section.theme)]}>{section.description}</p> : null}
          <div class:list={["mt-10", cardGrid(section.columns ?? 3)]}>
            {section.cards.map((card) =>
              card.href ? (
                <a
                  href={card.href}
                  class:list={[
                    "block h-full rounded-[1.5rem] border p-8 transition hover:-translate-y-0.5",
                    section.theme === "dark"
                      ? "border-white/12 bg-black/14 hover:bg-black/22"
                      : "border-[color:var(--dd-border)] bg-dd-cream/60 hover:border-[color:var(--dd-red)]",
                  ]}
                >
                  <h3 class="text-xl font-bold">{card.title}</h3>
                  <p class:list={["mt-3 text-sm leading-7 sm:text-base", muted(section.theme)]}>{card.description}</p>
                  <span
                    class:list={[
                      "mt-5 inline-flex text-xs font-semibold uppercase tracking-[0.14em]",
                      section.theme === "dark" ? "text-white/82" : "text-[color:var(--dd-red)]",
                    ]}
                  >
                    Explore page
                  </span>
                </a>
              ) : (
                <div
                  class:list={[
                    "h-full rounded-[1.5rem] border p-8",
                    section.theme === "dark" ? "border-white/12 bg-black/14" : "border-[color:var(--dd-border)] bg-dd-cream/60",
                  ]}
                >
                  <h3 class="text-xl font-bold">{card.title}</h3>
                  <p class:list={["mt-3 text-sm leading-7 sm:text-base", muted(section.theme)]}>{card.description}</p>
                </div>
              ),
            )}
          </div>
        </section>
      ) : section.kind === "list" ? (
        <section data-section-index={index} class:list={["scroll-mt-28 border px-8 py-12 sm:px-10 sm:py-14", sectionShell(section.theme)]}>
          {section.eyebrow ? <p class={eyebrow(section.theme)}>{section.eyebrow}</p> : null}
          <h2 class="mt-3 font-display text-3xl font-extrabold tracking-tight sm:text-4xl">{section.title}</h2>
          {section.description ? <p class:list={["mt-4 max-w-3xl leading-8", muted(section.theme)]}>{section.description}</p> : null}
          <ul
            class:list={[
              "mt-10 grid gap-4 sm:text-base md:gap-6",
              section.columns === 4 ? "md:grid-cols-2 xl:grid-cols-4" : section.columns === 2 ? "md:grid-cols-2" : "md:grid-cols-2 xl:grid-cols-3",
            ]}
          >
            {section.items.map((item) => (
              <li
                class:list={[
                  "rounded-2xl border px-6 py-4 text-sm leading-7 md:text-base",
                  section.theme === "dark" ? "border-white/12 bg-black/14" : "border-[color:var(--dd-border)] bg-dd-cream/40",
                ]}
              >
                {item}
              </li>
            ))}
          </ul>
        </section>
      ) : section.kind === "team" ? (
        <section data-section-index={index} class="scroll-mt-28 text-[color:var(--dd-copy)]">
          {section.eyebrow ? (
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[color:var(--dd-red-bright)]">{section.eyebrow}</p>
          ) : null}
          <h2 class="mt-4 max-w-3xl font-display text-4xl font-extrabold tracking-tight sm:text-5xl">{section.title}</h2>
          {section.description ? (
            <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--dd-muted)] sm:text-lg">{section.description}</p>
          ) : null}
          <div class="mt-10 grid gap-6 lg:grid-cols-2">
            {section.members.map((member) => (
              <article class="h-full overflow-hidden rounded-[1.75rem] border border-[color:var(--dd-border)] bg-white shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
                <div class="aspect-[16/10] max-h-80 min-h-[12rem] overflow-hidden sm:aspect-auto sm:h-80">
                  <ContentImage
                    src={member.imageSrc}
                    alt={member.imageAlt}
                    width={900}
                    height={900}
                    loading="lazy"
                    decoding="async"
                    sizes="(max-width: 1024px) 100vw, 50vw"
                    class="h-full w-full object-cover"
                  />
                </div>
                <div class="p-7">
                  <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[color:var(--dd-red-bright)]">{member.role}</p>
                  <h3 class="mt-3 font-display text-3xl font-bold text-[color:var(--dd-copy)]">{member.name}</h3>
                  <div class="mt-5 space-y-4 text-sm leading-7 text-[color:var(--dd-muted)]">
                    {member.bio.map((b) => (
                      <p>{b}</p>
                    ))}
                  </div>
                  <ul class="mt-6 space-y-3">
                    {member.highlights.map((h) => (
                      <li class="rounded-2xl border border-[color:var(--dd-border)] bg-dd-cream px-4 py-3 text-sm leading-7 text-[color:var(--dd-copy)]">
                        {h}
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))}
          </div>
        </section>
      ) : null,
    )
  }

  {
    cta ? (
      <DetailPageCta
        theme={cta.theme}
        title={cta.title}
        description={cta.description}
        primaryAction={cta.primaryAction}
        secondaryAction={cta.secondaryAction}
      />
    ) : null
  }
</div>
