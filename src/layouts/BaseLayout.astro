---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader";
import SiteFooter from "../components/SiteFooter.astro";
import {
  navigationGroups,
  primaryNavigation,
  siteMetadata,
} from "../content/siteContent";
import {
  buildPageMetadata,
  getOrganizationJsonLd,
  getWebsiteJsonLd,
} from "../lib/seo";

type Props = {
  title?: string;
  description?: string;
  path: string;
  imagePath?: string;
  imageAlt?: string;
  keywords?: readonly string[];
  /** LCP hero: emit `<link rel="preload" as="image">` when set (typically WebP URL from `getImage` or fallback public path). */
  lcpPreloadHref?: string;
};

const {
  title,
  description = siteMetadata.description,
  path,
  imagePath,
  imageAlt,
  keywords,
  lcpPreloadHref,
} = Astro.props;

const meta = buildPageMetadata({
  title,
  description,
  path,
  imagePath,
  imageAlt,
  keywords,
});

const orgJsonLd = getOrganizationJsonLd();
const websiteJsonLd = getWebsiteJsonLd();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    {lcpPreloadHref ? <link rel="preload" as="image" href={lcpPreloadHref} fetchpriority="high" /> : null}
    <meta name="generator" content={Astro.generator} />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="keywords" content={meta.keywords.join(", ")} />
    <link rel="canonical" href={meta.canonicalUrl} />

    <meta property="og:title" content={meta.openGraph.title} />
    <meta property="og:description" content={meta.openGraph.description} />
    <meta property="og:url" content={meta.openGraph.url} />
    <meta property="og:site_name" content={meta.openGraph.siteName} />
    <meta property="og:locale" content={meta.openGraph.locale} />
    <meta property="og:type" content={meta.openGraph.type} />
    <meta property="og:image" content={meta.openGraph.imageUrl} />
    <meta property="og:image:alt" content={meta.openGraph.imageAlt} />

    <meta name="twitter:card" content={meta.twitter.card} />
    <meta name="twitter:title" content={meta.twitter.title} />
    <meta name="twitter:description" content={meta.twitter.description} />
    <meta name="twitter:image" content={meta.twitter.imageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
  </head>
  <body class="font-body min-h-screen bg-dd-cream text-dd-copy antialiased">
    <SiteHeader
      client:load
      primaryNavigation={primaryNavigation}
      navigationGroups={navigationGroups}
    />
    <slot />
    <SiteFooter />
  </body>
</html>
