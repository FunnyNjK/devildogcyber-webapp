---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ContactForm } from '../components/ContactForm';
import { contactPageContent } from '../content/contactContent';
import { footerContact } from '../content/siteContent';

const title = 'Contact DevilDog Cybersecurity';
const description =
  'Tell DevilDog where you need help — compliance, cybersecurity, monitoring, or training — and the team will follow up by email.';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const honeypotFieldName = import.meta.env.CONTACT_HONEYPOT_FIELD_NAME?.trim() || 'company_website';
---

<BaseLayout description={description} title={title} path="/contact">
  <main>
    <section class="relative overflow-hidden bg-[color:var(--dd-ink)] text-white">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(176,17,22,0.28),transparent_36%),linear-gradient(180deg,rgba(255,255,255,0.02),transparent_50%)]"
      />

      <div
        class="relative mx-auto grid w-full max-w-7xl gap-10 px-6 py-24 sm:py-28 lg:grid-cols-[1.1fr_.9fr] lg:items-center"
      >
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[color:var(--dd-red-bright)]">
            {contactPageContent.eyebrow}
          </p>
          <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            {contactPageContent.title}
          </h1>
          <p class="mt-6 text-base leading-8 text-white/82 sm:text-lg">
            {contactPageContent.subtitle}
          </p>

          <ul class="mt-8 grid gap-3 sm:grid-cols-2">
            {contactPageContent.supportingPoints.map((item) => (
              <li
                class="rounded-[1.4rem] border border-white/10 bg-white/6 px-4 py-4 text-sm leading-7 text-white/88 backdrop-blur-sm"
              >
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div
          class="rounded-[2rem] border border-white/10 bg-white/6 p-8 shadow-[0_24px_70px_rgba(0,0,0,0.28)] backdrop-blur-sm sm:p-10"
        >
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-white/60">
            {contactPageContent.responseTitle}
          </p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
            Give the team the context they need.
          </h2>
          <p class="mt-4 text-base leading-8 text-white/80">
            {contactPageContent.responseDescription}
          </p>

          <ul class="mt-8 space-y-3">
            {contactPageContent.responseHighlights.map((item) => (
              <li class="rounded-[1.35rem] border border-white/10 bg-black/20 px-4 py-3 text-sm leading-7 text-white">
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="py-24 sm:py-28">
      <div class="mx-auto grid w-full max-w-7xl gap-10 px-6 lg:grid-cols-[1.08fr_.92fr] lg:items-start">
        <div>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[color:var(--dd-red-bright)]">
              {contactPageContent.formIntroTitle}
            </p>
            <h2 class="mt-4 text-4xl font-extrabold tracking-tight text-[color:var(--dd-copy)] sm:text-5xl">
              Security, compliance, and delivery questions can start here.
            </h2>
            <p class="mt-4 text-base leading-8 text-[color:var(--dd-muted)] sm:text-lg">
              {contactPageContent.formIntroDescription}
            </p>
          </div>

          <div class="mt-10">
            <ContactForm client:visible honeypotFieldName={honeypotFieldName} siteKey={turnstileSiteKey} />
          </div>
        </div>

        <section
          class="rounded-[2rem] border border-[color:var(--dd-border)] bg-white p-8 text-[color:var(--dd-copy)] shadow-[0_18px_50px_rgba(15,23,42,0.08)] sm:p-10"
        >
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[color:var(--dd-red-bright)]">
            Reach DevilDog Directly
          </p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-[color:var(--dd-copy)]">
            Prefer the usual contact channels?
          </h2>
          <div class="mt-6 space-y-4 text-base leading-8 text-[color:var(--dd-muted)]">
            <p>
              <span class="font-semibold text-[color:var(--dd-copy)]">Email:</span>{' '}
              {footerContact.email}
            </p>
            <div>
              <span class="font-semibold text-[color:var(--dd-copy)]">Address:</span>
              <div class="mt-2 space-y-1">
                {footerContact.addressLines.map((line) => (
                  <div>{line}</div>
                ))}
              </div>
            </div>
          </div>

          <div class="mt-8">
            <a
              href="/services"
              class="inline-flex rounded-full border border-[color:var(--dd-border)] bg-[color:var(--dd-cream)] px-5 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--dd-red-deep)] transition hover:border-[color:var(--dd-red)] hover:text-[color:var(--dd-red)]"
            >
              Explore Services
            </a>
          </div>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>
