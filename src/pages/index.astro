---
import { getImage } from "astro:assets";

import ContentImage from "../components/ContentImage.astro";
import ServiceHighlightIcon from "../components/home/ServiceHighlightIcon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  featureCards,
  heroContent,
  missionContent,
  serviceHighlights,
  siteMetadata,
  storyContent,
} from "../content/siteContent";
import { getImageFromPublicPath } from "../lib/contentImages";

const heroMeta = getImageFromPublicPath(heroContent.imageSrc);
const lcpPreloadHref = heroMeta
  ? (await getImage({ src: heroMeta, width: 1200, format: "webp" })).src
  : heroContent.imageSrc;
---

<BaseLayout
  description={siteMetadata.description}
  path="/"
  imagePath={siteMetadata.defaultOgImage}
  imageAlt={heroContent.imageAlt}
  lcpPreloadHref={lcpPreloadHref}
>
  <main>
    <section
      id="hero"
      class="relative overflow-hidden bg-[color:var(--dd-ink)] text-white scroll-mt-28"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(176,17,22,0.24),transparent_35%),linear-gradient(180deg,rgba(255,255,255,0.02),transparent_52%)]"
      />

      <div
        class="relative mx-auto grid w-full max-w-7xl gap-12 px-6 pb-28 pt-16 lg:grid-cols-[1.05fr_.95fr] lg:items-center lg:pb-36 lg:pt-24"
      >
        <div class="max-w-3xl text-center lg:text-left">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-[color:var(--dd-red-bright)]"
          >
            {heroContent.eyebrow}
          </p>
          <h1
            class="mt-6 font-display text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl"
          >
            {heroContent.title}
          </h1>

          <div class="mt-8 space-y-5 text-base leading-8 text-white/80 sm:text-lg">
            {heroContent.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>

        <div class="relative mx-auto w-full max-w-2xl">
          <div
            class="absolute -inset-4 rounded-[2rem] bg-[linear-gradient(135deg,rgba(176,17,22,0.45),transparent_70%)] blur-2xl"
          />
          <div
            class="relative overflow-hidden rounded-[2rem] border border-white/10 shadow-[0_28px_80px_rgba(0,0,0,0.35)]"
          >
            <ContentImage
              src={heroContent.imageSrc}
              alt={heroContent.imageAlt}
              width={1200}
              height={900}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              sizes="(max-width: 1024px) 100vw, 42vw"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="relative z-10 -mt-[4.5rem] scroll-mt-28">
      <div class="mx-auto grid w-full max-w-7xl gap-6 px-6 pb-20 md:grid-cols-2 xl:grid-cols-4">
        {
          featureCards.map((card) => (
            <a
              href={card.href}
              class="h-full overflow-hidden rounded-[1.75rem] border border-[color:var(--dd-border)] bg-white text-[color:var(--dd-copy)] shadow-[0_20px_60px_rgba(15,23,42,0.12)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_24px_68px_rgba(15,23,42,0.16)]"
            >
              <div class="h-52 overflow-hidden">
                <ContentImage
                  src={card.imageSrc}
                  alt={card.imageAlt}
                  width={900}
                  height={700}
                  loading="lazy"
                  decoding="async"
                  sizes="(max-width: 1280px) 50vw, 25vw"
                  class="h-full w-full object-cover"
                />
              </div>
              <div class="p-6">
                <h2 class="text-2xl font-bold text-[color:var(--dd-red)]">{card.title}</h2>
                <p class="mt-4 text-sm leading-7 text-[color:var(--dd-muted)]">
                  {card.description}
                </p>
                <span class="mt-5 inline-flex text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--dd-red)]">
                  Explore page
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section
      id="services"
      class="scroll-mt-28 bg-[linear-gradient(180deg,var(--dd-red),var(--dd-red-deep))] py-20 text-white"
    >
      <div class="mx-auto w-full max-w-7xl px-6">
        <div class="grid gap-12 lg:grid-cols-[.95fr_1.05fr] lg:items-center">
          <div class="overflow-hidden rounded-[2rem] border border-white/10 shadow-[0_24px_65px_rgba(0,0,0,0.18)]">
            <ContentImage
              src={missionContent.imageSrc}
              alt={missionContent.imageAlt}
              width={1200}
              height={900}
              loading="lazy"
              decoding="async"
              sizes="(max-width: 1024px) 100vw, 45vw"
              class="h-full w-full object-cover"
            />
          </div>

          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-white/60">Mission</p>
            <h2 class="mt-5 font-display text-4xl font-extrabold tracking-tight sm:text-5xl">
              {missionContent.title}
            </h2>
            <div class="mt-6 space-y-5 text-base leading-8 text-white/80">
              {missionContent.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
        </div>

        <div class="mt-16 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            serviceHighlights.map((service) => (
              <a
                href={service.href}
                id={`service-${service.slug}`}
                class="h-full scroll-mt-28 rounded-[1.75rem] border border-white/10 bg-white p-7 text-[color:var(--dd-copy)] shadow-[0_18px_40px_rgba(0,0,0,0.12)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_22px_48px_rgba(0,0,0,0.18)]"
              >
                <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-[color:var(--dd-red)] text-white shadow-[0_12px_24px_rgba(108,4,4,0.22)]">
                  <ServiceHighlightIcon icon={service.icon} />
                </div>
                <h3 class="mt-6 text-2xl font-bold text-[color:var(--dd-copy)]">
                  {service.title}
                </h3>
                <p class="mt-3 text-sm leading-7 text-[color:var(--dd-muted)]">
                  {service.description}
                </p>
                <span class="mt-5 inline-flex text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--dd-red)]">
                  Explore service
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="story" class="scroll-mt-28 py-24 sm:py-28">
      <div class="mx-auto w-full max-w-7xl px-6">
        <div class="max-w-3xl">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-[color:var(--dd-red-bright)]"
          >
            About Us
          </p>
          <h2
            class="mt-4 font-display text-4xl font-extrabold tracking-tight text-[color:var(--dd-copy)] sm:text-5xl"
          >
            {storyContent.title}
          </h2>
          <p class="mt-3 text-xl font-semibold text-[color:var(--dd-red)]">
            {storyContent.subtitle}
          </p>
        </div>

        <div class="mt-10 grid gap-10 lg:grid-cols-[.95fr_1.05fr] lg:items-center lg:py-4">
          <div
            class="overflow-hidden rounded-[2rem] border border-[color:var(--dd-border)] bg-white shadow-[0_18px_50px_rgba(15,23,42,0.12)]"
          >
            <ContentImage
              src={storyContent.imageSrc}
              alt={storyContent.imageAlt}
              width={1200}
              height={900}
              loading="lazy"
              decoding="async"
              sizes="(max-width: 1024px) 100vw, 48vw"
              class="h-full w-full object-cover"
            />
          </div>

          <div
            class="rounded-[2rem] border border-[color:var(--dd-border)] bg-white p-8 shadow-[0_18px_50px_rgba(15,23,42,0.08)] sm:p-10"
          >
            <div class="space-y-5 text-base leading-8 text-[color:var(--dd-muted)]">
              {storyContent.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
